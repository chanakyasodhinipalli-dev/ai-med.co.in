# AI.MeD — .htaccess for GoDaddy cPanel hosting (ai-med.co.in)
# AutoSSL (cPanel/Sectigo), HTTPS redirect, www→non-www, clean URLs, custom 404
#
# AutoSSL SETUP (GoDaddy cPanel):
# 1. Log in to GoDaddy → My Products → Hosting → Manage → cPanel
# 2. Go to cPanel → Security → SSL/TLS Status
# 3. Ensure AutoSSL is enabled (cPanel → SSL/TLS Status → Run AutoSSL)
# 4. Add both ai-med.co.in AND www.ai-med.co.in to AutoSSL coverage
# 5. AutoSSL will provision and auto-renew a free Sectigo certificate
# 6. Allow the .well-known/acme-challenge path below for domain validation

# ============================================================
# 1. AUTOSSL — ALLOW ACME CHALLENGE (do not block)
# ============================================================
RewriteEngine On
RewriteRule ^\.well-known/acme-challenge/ - [L]

# ============================================================
# 2. HTTPS REDIRECT
# ============================================================
RewriteCond %{HTTPS} off
RewriteRule ^(.*)$ https://%{HTTP_HOST}%{REQUEST_URI} [L,R=301]

# ============================================================
# 3. WWW → NON-WWW REDIRECT (www.ai-med.co.in → ai-med.co.in)
# ============================================================
RewriteCond %{HTTP_HOST} ^www\.ai-med\.co\.in$ [NC]
RewriteRule ^(.*)$ https://ai-med.co.in/$1 [R=301,L]

# ============================================================
# 4. CLEAN URLs (optional — remove .html extension)
# ============================================================
# Redirect .html to clean URL
RewriteCond %{THE_REQUEST} /([^.]+)\.html [NC]
RewriteRule ^ /%1 [NC,L,R=301]

# Serve .html files without extension
RewriteCond %{REQUEST_FILENAME} !-d
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME}.html -f
RewriteRule ^(.+)$ $1.html [L]

# ============================================================
# 5. CUSTOM 404 PAGE
# ============================================================
ErrorDocument 404 /404.html

# ============================================================
# 6. SECURITY HEADERS
# ============================================================
<IfModule mod_headers.c>
  Header set X-Content-Type-Options "nosniff"
  Header set X-Frame-Options "SAMEORIGIN"
  Header set X-XSS-Protection "1; mode=block"
  Header set Referrer-Policy "strict-origin-when-cross-origin"
</IfModule>

# ============================================================
# 7. CACHING
# ============================================================
<IfModule mod_expires.c>
  ExpiresActive On
  ExpiresByType text/css "access plus 1 month"
  ExpiresByType application/javascript "access plus 1 month"
  ExpiresByType image/svg+xml "access plus 1 month"
  ExpiresByType image/png "access plus 1 month"
  ExpiresByType image/jpeg "access plus 1 month"
  ExpiresByType image/x-icon "access plus 1 year"
  ExpiresByType font/woff2 "access plus 1 year"
  ExpiresByType text/html "access plus 0 seconds"
</IfModule>

# ============================================================
# 8. GZIP COMPRESSION
# ============================================================
<IfModule mod_deflate.c>
  AddOutputFilterByType DEFLATE text/html text/css application/javascript application/json image/svg+xml text/xml
</IfModule>
